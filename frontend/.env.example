# Strapi API (public — safe to expose to browser)
NEXT_PUBLIC_STRAPI_URL=http://localhost:1337

# Strapi API Token (private — server-side only, never expose to browser)
# Generate in Strapi Admin → Settings → API Tokens
STRAPI_API_TOKEN=your_strapi_api_token_here

# Strapi hostname for Next/Image remote patterns (production only)
STRAPI_HOSTNAME=your-strapi-domain.com

# Site URL (used for canonical URLs / sitemap)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
